# .env.example — copy to .env and fill in values
# cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Auth keys (change these — defaults are insecure) ─────────────────────────
MC_SESSION_KEY=your-session-key-here
MC_ADMIN_KEY=your-admin-key-here

# ── Identity ──────────────────────────────────────────────────────────────────
MC_HUMAN_ID=your-name-or-id
MC_AGENT_ID=claude-code

# ── Container endpoint ────────────────────────────────────────────────────────
MC_BASE_URL=http://localhost:4200

# ── Optional ──────────────────────────────────────────────────────────────────
# MC_HOST_PORT=4200                    # host port to bind to
# MC_DB_PASSWORD=dev                   # only needed if customizing
# MC_EMBEDDING_MODEL=nomic-embed-text  # or mxbai-embed-large for higher quality
# MC_SESSION_ID=                       # set per-session by your adapter
